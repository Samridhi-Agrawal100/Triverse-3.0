---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import logoCff from "../images/event/LOGO_cff.png";
import theDropt from "../images/event/TheDropt.png";
import frame87 from "../images/event/Frame 87 (1).png";

const events = [
  {
    id: 1,
    image: logoCff,
    cardTitle: "BREAKIT",
    tagline: "Deconstruct. Stress Test. Redesign.",
    objective:
      "Participants analyze and rethink real-world tech products, exposing system flaws and proposing grounded fixes — no code required.",
    color: "#a855f7",
    glowColor: "rgba(168,85,247,1)",
    day: "Day 1",
    tag: "Competition",
    details: [
      "Identify critical vulnerabilities in existing tech systems",
      "Propose innovative solutions without writing code",
      "Present redesigned architecture to judges",
    ],
    participants: "Teams of 3-4",
    duration: "8 hours",
  },
  {
    id: 2,
    image: theDropt,
    cardTitle: "THE DROP",
    tagline: "Launch the Future. Even If It's Fake.",
    objective:
      "Teams invent fictional future-tech products and launch them like real startups — blending storytelling, design, and satire.",
    color: "#d946ef",
    glowColor: "rgba(217,70,239,1)",
    day: "Day 2",
    tag: "Creative",
    details: [
      "Create a fictional future-tech product concept",
      "Develop complete branding and marketing strategy",
      "Build a compelling product launch presentation",
    ],
    participants: "Teams of 2-5",
    duration: "10 hours",
  },
  {
    id: 3,
    image: frame87,
    cardTitle: "BET FOR TECH 3.0",
    tagline: "Code. Bet. Conquer.",
    objective:
      "Tests participants' coding skills, strategic thinking, and risk-taking ability by combining problem-solving with betting and psychological decision-making in a high-stakes competitive format.",
    color: "#ec4899",
    glowColor: "rgba(236,72,153,1)",
    day: "Day 3",
    tag: "Hackathon",
    details: [
      "Solve complex coding challenges under pressure",
      "Make strategic bets on your solutions",
      "Compete in real-time against other teams",
    ],
    participants: "Individual or Pairs",
    duration: "6 hours",
  },
];
---

<Layout title="Events - Triverse">
  <!-- Fixed Background Video -->
  <div class="video-background">
    <video autoplay muted loop playsinline preload="auto" class="bg-video">
      <source
        src="https://res.cloudinary.com/dtxhjkgdu/video/upload/v1769102015/Event_Background_vpzjlx.mp4"
        type="video/mp4"
      />
    </video>
    <div class="video-overlay"></div>
  </div>

  <main class="events-main">
    <!-- Vertical Timeline Line -->
    <div class="timeline-vertical"></div>

    <!-- Section Header -->
    <header class="chronicle-header">
      <h1 class="chronicle-title">
        <span class="title-line" id="titleLine1">
          <span class="letter">T</span><span class="letter">H</span><span class="letter">E</span>
        </span>
        <br/>
        <span class="title-line" id="titleLine2">
          <span class="letter">E</span><span class="letter">V</span><span class="letter">E</span><span class="letter">N</span><span class="letter">T</span><span class="letter">S</span>
        </span>
      </h1>
      <p class="chronicle-subtitle" id="subtitleText">Three days of innovation, competition & creativity</p>
    </header>

    <!-- Timeline Content -->
    <div class="chronicle-content">
      {events.map((event, index) => {
        const isReversed = index % 2 !== 0;
        return (
          <div class="chronicle-event group" data-event-id={event.id}>
            <!-- Day Number - Large Text -->
            <div class="event-day-col">
              <span class="day-large-text" style={`--hover-color: ${event.color}20;`}>
                {event.day.replace("Day ", "0")}
              </span>
              <span class="day-label" style={`color: ${event.color};`}>
                {event.day.toUpperCase()}
              </span>
            </div>

            <!-- Timeline Dot -->
            <div class="timeline-dot-anchor">
              <div class="timeline-dot" style={`background-color: ${event.color}; box-shadow: 0 0 20px ${event.glowColor};`}></div>
            </div>

            <!-- Content + Image -->
            <div class={`event-content-col ${isReversed ? "content-reversed" : ""}`}>
              <div class={`event-inner ${isReversed ? "inner-reversed" : ""}`}>
                <!-- Text Content -->
                <div class={`event-text ${isReversed ? "text-right-align" : ""}`}>
                  <div class="event-tag" style={`color: ${event.color};`}>
                    {event.tag}
                  </div>
                  <h2 class="event-title">{event.cardTitle}</h2>
                  <p class="event-tagline">{event.tagline}</p>
                  <p class="event-objective">{event.objective}</p>

                  <!-- Meta -->
                  <div class={`event-meta ${isReversed ? "meta-right" : ""}`}>
                    <div class="meta-chip">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={`color: ${event.color};`}>
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                      <span>{event.participants}</span>
                    </div>
                    <div class="meta-chip">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={`color: ${event.color};`}>
                        <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      <span>{event.duration}</span>
                    </div>
                  </div>
                </div>

                <!-- Image -->
                <div class="event-image-container">
                  <div class="event-image-glow" style={`background: ${event.color}08;`}></div>
                  <Image
                    src={event.image}
                    alt={event.cardTitle}
                    class="event-image"
                    width={320}
                    height={320}
                  />
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Decorative Floating Blurs -->
    <div class="deco-blur deco-blur-1"></div>
    <div class="deco-blur deco-blur-2"></div>
  </main>
</Layout>

<style is:global>
  :root {
    --bg-dark: #0a0e1a;
    --purple-bright: #b48bff;
  }
  html {
    background-color: var(--bg-dark);
  }
  body {
    background-color: transparent;
    color: #ffffff;
    margin: 0;
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    overflow-x: hidden;
  }
</style>

<style>
  /* ==================== FIXED VIDEO ==================== */
  .video-background {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .bg-video {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    filter: blur(8px) brightness(0.3);
  }
  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,14,26,0.6) 0%, rgba(10,14,26,0.2) 50%, rgba(10,14,26,0.7) 100%);
  }

  /* ==================== MAIN ==================== */
  .events-main {
    position: relative;
    min-height: 100vh;
    z-index: 2;
    padding-top: 120px;
    padding-bottom: 160px;
    overflow: hidden;
  }

  /* ==================== VERTICAL TIMELINE ==================== */
  .timeline-vertical {
    position: absolute;
    left: 25%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(180,139,255,0.3), transparent);
    box-shadow: 0 0 15px rgba(180,139,255,0.2);
    pointer-events: none;
  }

  /* ==================== HEADER ==================== */
  .chronicle-header {
    max-width: 1280px;
    margin: 0 auto 160px;
    padding: 0 48px;
    position: relative;
    z-index: 10;
  }
  .chronicle-title {
    font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: #fff;
    opacity: 0.9;
    margin: 0 0 16px;
  }
  .title-line {
    display: inline-block;
    overflow: hidden;
  }
  .letter {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.4s ease;
  }
  .letter.pop {
    transform: translateY(0);
    opacity: 1;
  }
  .chronicle-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.45);
    max-width: 320px;
    margin: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .chronicle-subtitle.pop {
    opacity: 1;
    transform: translateY(0);
  }

  /* ==================== TIMELINE CONTENT ==================== */
  .chronicle-content {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
    position: relative;
    z-index: 10;
  }

  /* ==================== CHRONICLE EVENT ==================== */
  .chronicle-event {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-bottom: 200px;
  }
  .chronicle-event:last-child {
    margin-bottom: 80px;
  }

  /* ==================== DAY COLUMN ==================== */
  .event-day-col {
    width: 25%;
    flex-shrink: 0;
    display: flex;
    justify-content: flex-end;
    padding-right: 80px;
    position: relative;
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-day-col {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.1s;
  }

  .day-large-text {
    font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    font-weight: 100;
    font-size: clamp(5rem, 12vw, 10rem);
    line-height: 1;
    color: rgba(255,255,255,0.06);
    transition: color 0.7s ease;
    user-select: none;
  }
  .chronicle-event:hover .day-large-text {
    color: var(--hover-color, rgba(180,139,255,0.15));
  }
  .day-label {
    position: absolute;
    top: 50%;
    right: 40px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    transform: rotate(90deg);
    transform-origin: right center;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.5s ease;
    transition-delay: 0s;
  }
  .chronicle-event.revealed .day-label {
    opacity: 1;
    transition-delay: 0.4s;
  }

  /* ==================== TIMELINE DOT ==================== */
  .timeline-dot-anchor {
    width: 0;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 40px;
    flex-shrink: 0;
  }
  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    z-index: 20;
    flex-shrink: 0;
    transform: scale(0);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .timeline-dot {
    transform: scale(1);
    transition-delay: 0.25s;
  }

  /* ==================== CONTENT ANIMATIONS ==================== */
  .event-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .event-image-container {
    width: 240px;
    height: 240px;
    flex-shrink: 0;
    position: relative;
    opacity: 0;
    transform: translateY(40px) scale(0.85);
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-image-container {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.65s;
    animation: imageBreath 3s ease-in-out 1.5s infinite;
  }
  @keyframes imageBreath {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-4px) scale(1.06); }
  }

  .event-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 4px 12px;
    border-radius: 9999px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    width: fit-content;
    opacity: 0;
    transform: translateY(12px) translateX(-15px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-tag {
    opacity: 1;
    transform: translateY(0) translateX(0);
    transition-delay: 0.3s;
  }

  .event-meta {
    display: flex;
    gap: 16px;
    padding-top: 8px;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-meta {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.75s;
  }
  .meta-chip {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    transition-delay: 0s;
  }
  .chronicle-event.revealed .meta-chip:nth-child(1) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.8s;
  }
  .chronicle-event.revealed .meta-chip:nth-child(2) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.9s;
  }

  /* ==================== CONTENT COLUMN ==================== */
  .event-content-col {
    flex: 1;
    padding-left: 80px;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-content-col {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
  }
  .event-inner {
    display: flex;
    align-items: flex-start;
    gap: 48px;
  }
  .event-inner.inner-reversed {
    flex-direction: row-reverse;
  }

  /* ==================== EVENT TEXT ==================== */
  .event-text.text-right-align {
    text-align: right;
  }
  .text-right-align .event-tag {
    margin-left: auto;
  }

  .event-title {
    font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
    line-height: 1.1;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-title {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.4s;
  }

  .event-tagline {
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
    font-style: italic;
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-tagline {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.5s;
  }

  .event-objective {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin: 0;
    max-width: 380px;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0s;
  }
  .chronicle-event.revealed .event-objective {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.6s;
  }
  .text-right-align .event-objective {
    margin-left: auto;
  }

  /* ==================== META ==================== */
  .event-meta.meta-right {
    justify-content: flex-end;
  }
  .meta-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
    padding: 6px 12px;
    background: rgba(255,255,255,0.04);
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  /* ==================== EVENT IMAGE ==================== */
  .event-image-glow {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    filter: blur(50px);
  }
  .event-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    position: relative;
    z-index: 10;
    transition: transform 0.5s ease;
    filter: drop-shadow(0 10px 30px rgba(0,0,0,0.5));
  }
  .chronicle-event:hover .event-image {
    transform: scale(1.1);
  }

  /* ==================== DECORATIVE BLURS ==================== */
  .deco-blur {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(120px);
  }
  .deco-blur-1 {
    top: 20%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: rgba(168,85,247,0.04);
  }
  .deco-blur-2 {
    bottom: 20%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: rgba(217,70,239,0.04);
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 1024px) {
    .event-day-col {
      padding-right: 48px;
    }
    .event-content-col {
      padding-left: 48px;
    }
    .event-inner {
      flex-direction: column !important;
      gap: 24px;
    }
    .event-image-container {
      width: 180px;
      height: 180px;
    }
    .text-right-align {
      text-align: left;
    }
    .text-right-align .event-tag,
    .text-right-align .event-objective {
      margin-left: 0;
    }
    .event-meta.meta-right {
      justify-content: flex-start;
    }
  }

  @media (max-width: 768px) {
    .events-main {
      padding-top: 100px;
      padding-bottom: 80px;
    }

    .timeline-vertical {
      display: none;
    }

    .chronicle-header {
      padding: 0 24px;
      margin-bottom: 80px;
    }
    .chronicle-title {
      font-size: clamp(3rem, 14vw, 5rem);
    }

    .chronicle-content {
      padding: 0 24px;
    }

    .chronicle-event {
      flex-direction: column;
      gap: 16px;
      margin-bottom: 100px;
    }

    .event-day-col {
      width: 100%;
      justify-content: flex-start;
      padding-right: 0;
    }
    .day-large-text {
      font-size: 4rem;
    }
    .day-label {
      position: static;
      transform: none;
      margin-left: 12px;
    }
    .event-day-col {
      display: flex;
      align-items: center;
    }

    .timeline-dot-anchor {
      display: none;
    }

    .event-content-col {
      padding-left: 0;
    }
    .event-inner {
      flex-direction: column !important;
      gap: 24px;
    }
    .event-image-container {
      width: 160px;
      height: 160px;
    }
  }

  @media (max-width: 480px) {
    .chronicle-header {
      padding: 0 16px;
    }
    .chronicle-content {
      padding: 0 16px;
    }
    .day-large-text {
      font-size: 3rem;
    }
    .event-title {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  // === Header letter-by-letter pop-up animation ===
  function animateHeader() {
    const line1Letters = document.querySelectorAll("#titleLine1 .letter");
    const line2Letters = document.querySelectorAll("#titleLine2 .letter");
    const subtitle = document.getElementById("subtitleText");
    const letterDelay = 80; // ms between each letter

    // Animate "THE" letters
    line1Letters.forEach((letter, i) => {
      setTimeout(() => letter.classList.add("pop"), 200 + i * letterDelay);
    });

    // Animate "EVENTS" letters after "THE" finishes
    const line2Start = 200 + line1Letters.length * letterDelay + 150;
    line2Letters.forEach((letter, i) => {
      setTimeout(() => letter.classList.add("pop"), line2Start + i * letterDelay);
    });

    // Animate subtitle after all letters finish
    const subtitleStart = line2Start + line2Letters.length * letterDelay + 200;
    setTimeout(() => subtitle?.classList.add("pop"), subtitleStart);
  }
  animateHeader();

  // === Intersection Observer with reverse scroll support ===
  // Delay observer start so the first event (already in viewport)
  // doesn't instantly reveal — user gets to see the animation on load/reload
  const eventItems = document.querySelectorAll(".chronicle-event");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("revealed");
        } else {
          // Reverse animation when scrolling away
          e.target.classList.remove("revealed");
        }
      });
    },
    { threshold: 0.12 }
  );

  // Wait for the user's first scroll to start observing (desktop),
  // or auto-start after header animation finishes (mobile)
  let observerStarted = false;
  function startObserving() {
    if (observerStarted) return;
    observerStarted = true;
    eventItems.forEach((item) => observer.observe(item));
    window.removeEventListener("scroll", startObserving);
  }

  const isMobile = window.innerWidth <= 768;
  if (isMobile) {
    // On mobile, auto-start after header animation (~1.5s)
    setTimeout(startObserving, 1500);
  }
  // Always listen for scroll as a fallback / desktop trigger
  window.addEventListener("scroll", startObserving, { passive: true });

  // === Move video to fixed container ===
  const videoContainer = document.querySelector(".video-background");
  const fixedContainer = document.getElementById("fixed-video-container");
  if (videoContainer && fixedContainer) fixedContainer.appendChild(videoContainer);

  // === Footer reveal ===
  window.addEventListener("load", () => {
    const footer = document.querySelector("footer");
    if (!footer) return;
    footer.classList.add("footer-animate");
    footer.classList.remove("footer-visible");
    window.addEventListener("scroll", () => {
      const pct =
        (window.scrollY + window.innerHeight) /
        document.documentElement.scrollHeight;
      if (pct > 0.8) footer.classList.add("footer-visible");
      else footer.classList.remove("footer-visible");
    });
  });
