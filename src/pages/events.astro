---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import logoCff from "../images/event/LOGO_cff.png";
import theDropt from "../images/event/TheDropt.png";
import frame87 from "../images/event/Frame 87 (1).png";

const events = [
	{
		id: 1,
		image: logoCff,
		cardTitle: "BREAKIT",
		tagline: "Deconstruct. Stress Test. Redesign.",
		objectiveTitle: "🎯 Objective",
		objective:
			"Participants analyze and rethink real-world tech products, exposing system flaws and proposing grounded fixes — no code required.",
		color: "#a855f7",
		day: "Day 1",
	},
	{
		id: 2,
		image: theDropt,
		cardTitle: "THE DROP",
		tagline: "Launch the Future. Even If It's Fake.",
		objectiveTitle: "🎯 Objective",
		objective:
			"Teams invent fictional future-tech products and launch them like real startups — blending storytelling, design, and satire.",
		color: "#d946ef",
		day: "Day 2",
	},
	{
		id: 3,
		image: frame87,
		cardTitle: "BET FOR TECH 3.0",
		tagline: "Code. Bet. Conquer.",
		objectiveTitle: "🎯 Objective",
		objective:
			"Tests participants' coding skills, strategic thinking, and risk-taking ability by combining problem-solving with betting and psychological decision-making in a high-stakes competitive format.",
		color: "#ec4899",
		day: "Day 3",
	},
];

/* Positions: top% centers card on SVG dot, side determines left/right of dot */
const positions = [
	{ top: "14%", side: "left" } /* dot at y=350/2000=17.5% */,
	{ top: "42%", side: "right" } /* dot at y=900/2000=45% */,
	{ top: "70%", side: "left" } /* dot at y=1450/2000=72.5% */,
];
---

<Layout title="Events - Triverse">
	<!-- Fixed Background Video -->
	<div class="video-background">
		<video autoplay muted loop playsinline preload="auto" class="bg-video">
			<source
				src="https://res.cloudinary.com/dtxhjkgdu/video/upload/v1769102015/Event_Background_vpzjlx.mp4"
				type="video/mp4"
			/>
		</video>
		<div class="video-overlay"></div>
	</div>

	<main class="events-page">
		<!-- Hero Section -->
		<section class="hero">
			<h1 class="page-title">The Events</h1>
			<p class="subtitle">
				Three days of innovation, competition & creativity
			</p>
			<div class="scroll-hint">
				<span>Scroll to explore</span>
				<div class="scroll-arrow">↓</div>
			</div>
		</section>

		<!-- Flowing Path Events -->
		<section class="path-section">
			<!-- SVG Curved Path with nodes ON the curve -->
			<svg
				class="curve-svg"
				viewBox="0 0 1000 2000"
				preserveAspectRatio="none"
				fill="none"
			>
				<defs>
					<linearGradient id="curveGrad" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#a855f7"></stop>
						<stop offset="50%" stop-color="#d946ef"></stop>
						<stop offset="100%" stop-color="#ec4899"></stop>
					</linearGradient>
					<filter id="curveGlow">
						<feGaussianBlur
							in="SourceGraphic"
							stdDeviation="3"
							result="blur"></feGaussianBlur>
						<feMerge>
							<feMergeNode in="blur"></feMergeNode>
							<feMergeNode in="SourceGraphic"></feMergeNode>
						</feMerge>
					</filter>
				</defs>
				<!-- Faint base curve -->
				<path
					d="M 500,0 C 500,140 180,180 180,350 C 180,530 820,560 820,900 C 820,1200 180,1230 180,1450 C 180,1650 500,1680 500,1800 L 500,2000"
					stroke="rgba(168,85,247,0.08)"
					stroke-width="2.5"
					fill="none"></path>
				<!-- Animated glowing curve -->
				<path
					id="curvePath"
					d="M 500,0 C 500,140 180,180 180,350 C 180,530 820,560 820,900 C 820,1200 180,1230 180,1450 C 180,1650 500,1680 500,1800 L 500,2000"
					stroke="url(#curveGrad)"
					stroke-width="2.5"
					fill="none"
					filter="url(#curveGlow)"></path>

				<!-- Day 1 arrow on curve pointing RIGHT toward card -->
				<polygon
					points="170,330 210,350 170,370"
					fill="#a855f7"
					opacity="0.9"
					class="svg-arrow"></polygon>
				<polygon
					points="165,325 215,350 165,375"
					fill="none"
					stroke="#a855f7"
					stroke-width="1.5"
					opacity="0.3"
					class="svg-arrow-ring"></polygon>

				<!-- Day 2 arrow on curve pointing LEFT toward card -->
				<polygon
					points="830,880 790,900 830,920"
					fill="#d946ef"
					opacity="0.9"
					class="svg-arrow"></polygon>
				<polygon
					points="835,875 785,900 835,925"
					fill="none"
					stroke="#d946ef"
					stroke-width="1.5"
					opacity="0.3"
					class="svg-arrow-ring"></polygon>

				<!-- Day 3 arrow on curve pointing RIGHT toward card -->
				<polygon
					points="170,1430 210,1450 170,1470"
					fill="#ec4899"
					opacity="0.9"
					class="svg-arrow"></polygon>
				<polygon
					points="165,1425 215,1450 165,1475"
					fill="none"
					stroke="#ec4899"
					stroke-width="1.5"
					opacity="0.3"
					class="svg-arrow-ring"></polygon>
			</svg>

			<!-- Event cards absolutely positioned to align with SVG dots -->
			{
				events.map((event, index) => (
					<div
						class={`event-card ${positions[index].side === "left" ? "card-left" : "card-right"}`}
						style={`top: ${positions[index].top}; --accent: ${event.color};`}
						data-event-id={event.id}
						data-day={event.day}
						data-title={event.cardTitle}
						data-tagline={event.tagline}
						data-objective-title={event.objectiveTitle}
						data-objective={event.objective}
					>
						<div class="card-bubble">
							<div class="card-image">
								<Image
									src={event.image}
									alt={event.cardTitle}
									class="card-img"
									width={260}
									height={170}
								/>
							</div>
							<div class="card-info">
								<span
									class="card-day"
									style={`color: ${event.color};`}
								>
									{event.day}
								</span>
								<h3 class="card-name">{event.cardTitle}</h3>
								<p class="card-tagline">{event.tagline}</p>
								<span class="card-hint">
									Click to explore →
								</span>
							</div>
						</div>
					</div>
				))
			}
		</section>
	</main>
</Layout>

<!-- Modal OUTSIDE Layout so it's not inside any scrollable wrapper -->
<div class="modal-overlay" id="eventModal">
	<div class="modal-card" id="modalCard">
		<button class="modal-close" id="modalClose" aria-label="Close modal">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
		<div class="modal-image-wrapper" id="modalImageWrapper"></div>
		<div class="modal-body">
			<span class="modal-day" id="modalDay"></span>
			<h2 class="modal-title" id="modalTitle"></h2>
			<p class="modal-tagline" id="modalTagline"></p>
			<div class="modal-divider"></div>
			<h4 class="modal-objective-title" id="modalObjectiveTitle"></h4>
			<p class="modal-objective" id="modalObjective"></p>
		</div>
	</div>
</div>

<style is:global>
	:root {
		--bg-dark: #0a0e1a;
		--purple-bright: #b48bff;
	}
	html {
		background-color: var(--bg-dark);
	}
	body {
		background-color: transparent;
		color: #ffffff;
		margin: 0;
		font-family:
			"Inter",
			system-ui,
			-apple-system,
			sans-serif;
		overflow-x: hidden;
	}
	body.modal-open {
		overflow: hidden !important;
	}
</style>

<style>
	/* ==================== FIXED VIDEO ==================== */
	.video-background {
		position: fixed;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		z-index: 0;
	}
	.bg-video {
		width: 100vw;
		height: 100vh;
		object-fit: cover;
		filter: blur(8px) brightness(0.35);
	}
	.video-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(10, 14, 26, 0.5) 0%,
			rgba(10, 14, 26, 0.2) 50%,
			rgba(10, 14, 26, 0.6) 100%
		);
	}

	/* ==================== PAGE ==================== */
	.events-page {
		position: relative;
		min-height: 100vh;
		z-index: 2;
	}

	/* ==================== HERO ==================== */
	.hero {
		text-align: center;
		padding: 120px 20px 40px;
		position: relative;
		z-index: 1;
	}
	.page-title {
		font-size: clamp(2.5rem, 8vw, 5rem);
		font-weight: 950;
		margin: 0 0 1rem;
		letter-spacing: -0.03em;
		background: linear-gradient(135deg, #fff 0%, var(--purple-bright) 100%);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.subtitle {
		font-size: clamp(1rem, 2.5vw, 1.3rem);
		color: rgba(255, 255, 255, 0.8);
		margin: 0 0 40px;
	}
	.scroll-hint {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		color: rgba(255, 255, 255, 0.35);
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.scroll-arrow {
		animation: bounce 1.5s ease infinite;
		font-size: 1.2rem;
	}
	@keyframes bounce {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(8px);
		}
	}

	/* ==================== PATH SECTION ==================== */
	.path-section {
		position: relative;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
		height: 1800px; /* fixed height so absolute children align with SVG */
	}

	/* SVG Curve behind cards */
	.curve-svg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 0;
	}
	#curvePath {
		stroke-dasharray: 3000;
		stroke-dashoffset: 3000;
	}
	/* Pulsing SVG arrows */
	.svg-arrow {
		animation: svgArrowPulse 2.5s ease-in-out infinite;
	}
	.svg-arrow-ring {
		animation: svgArrowRingPulse 2.5s ease-in-out infinite;
	}
	@keyframes svgArrowPulse {
		0%,
		100% {
			opacity: 0.7;
		}
		50% {
			opacity: 1;
		}
	}
	@keyframes svgArrowRingPulse {
		0%,
		100% {
			opacity: 0.15;
		}
		50% {
			opacity: 0.5;
		}
	}

	/* ==================== EVENT CARDS ==================== */
	.event-card {
		position: absolute;
		z-index: 1;
		cursor: pointer;
		opacity: 0;
		transform: translateY(30px);
		transition:
			opacity 0.7s ease,
			transform 0.7s ease;
	}
	.event-card.revealed {
		opacity: 1;
		transform: translateY(0);
	}

	/* Card sits further RIGHT of the left-side dot (dot at 18%) */
	.card-left {
		left: 35%;
		width: 58%;
	}
	/* Card sits further LEFT of the right-side dot (dot at 82%) */
	.card-right {
		right: 35%;
		width: 58%;
	}

	/* ==================== CARD BUBBLE ==================== */
	.card-bubble {
		display: flex;
		flex-direction: row;
		align-items: stretch;
		background: rgba(0, 0, 0, 0.65);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.4);
		width: 100%;
	}
	.card-right .card-bubble {
		flex-direction: row-reverse;
	}
	.event-card:hover .card-bubble {
		transform: translateY(-4px);
		border-color: var(--accent);
		box-shadow:
			0 16px 48px rgba(0, 0, 0, 0.5),
			0 0 24px rgba(168, 85, 247, 0.12);
	}

	/* Card image */
	.card-image {
		width: 220px;
		min-width: 220px;
		overflow: hidden;
		flex-shrink: 0;
	}
	.card-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}
	.event-card:hover .card-img {
		transform: scale(1.06);
	}

	/* Card text */
	.card-info {
		padding: 24px 28px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 6px;
	}
	.card-day {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}
	.card-name {
		font-size: 1.5rem;
		font-weight: 900;
		color: #fff;
		margin: 2px 0 0;
		line-height: 1.15;
	}
	.card-tagline {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.45);
		margin: 0;
		line-height: 1.4;
	}
	.card-hint {
		font-size: 0.7rem;
		color: rgba(255, 255, 255, 0.2);
		font-weight: 500;
		margin-top: 6px;
		transition: all 0.3s ease;
	}
	.event-card:hover .card-hint {
		color: var(--accent);
		transform: translateX(4px);
	}

	/* ==================== MODAL ==================== */
	.modal-overlay {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 20px;
		opacity: 0;
		visibility: hidden;
		transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.modal-overlay.active {
		opacity: 1;
		visibility: visible;
	}
	.modal-card {
		position: relative;
		width: min(600px, 95vw);
		max-height: 88vh;
		background: rgba(12, 12, 22, 0.97);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 24px;
		overflow: hidden;
		overflow-y: auto;
		transform: translateY(30px) scale(0.96);
		transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 40px 100px rgba(0, 0, 0, 0.7);
	}
	.modal-overlay.active .modal-card {
		transform: translateY(0) scale(1);
	}
	.modal-card::-webkit-scrollbar {
		width: 0;
	}
	.modal-close {
		position: absolute;
		top: 14px;
		right: 14px;
		z-index: 10;
		width: 38px;
		height: 38px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.15);
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(10px);
		color: #fff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s ease;
	}
	.modal-close:hover {
		background: rgba(255, 255, 255, 0.15);
		transform: rotate(90deg);
	}
	.modal-image-wrapper {
		width: 100%;
		height: 240px;
		overflow: hidden;
		position: relative;
		background: #111;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.modal-image-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
		display: block;
		padding: 20px;
	}
	.modal-image-wrapper::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 80px;
		background: linear-gradient(transparent, rgba(12, 12, 22, 0.97));
	}
	.modal-body {
		padding: 8px 32px 32px;
	}
	.modal-day {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--purple-bright);
		padding: 5px 14px;
		background: rgba(180, 139, 255, 0.1);
		border: 1px solid rgba(180, 139, 255, 0.2);
		border-radius: 50px;
		margin-bottom: 12px;
	}
	.modal-title {
		font-size: clamp(1.5rem, 5vw, 2.1rem);
		font-weight: 900;
		color: #fff;
		margin: 0 0 6px;
		line-height: 1.1;
	}
	.modal-tagline {
		font-size: 0.95rem;
		color: var(--purple-bright);
		font-weight: 600;
		margin: 0;
	}
	.modal-divider {
		width: 100%;
		height: 1px;
		margin: 16px 0;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.12),
			transparent
		);
	}
	.modal-objective-title {
		font-size: 0.9rem;
		color: var(--purple-bright);
		margin: 0 0 6px;
		font-weight: 700;
	}
	.modal-objective {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.65);
		line-height: 1.75;
		margin: 0;
	}

	/* ==================== RESPONSIVE ==================== */
	@media (max-width: 768px) {
		.hero {
			padding: 100px 20px 30px;
		}
		.path-section {
			height: auto;
			padding: 0 16px 80px;
		}
		.curve-svg {
			display: none;
		}

		.event-card {
			position: relative !important;
			top: auto !important;
			left: auto !important;
			right: auto !important;
			width: 100% !important;
			padding-left: 40px;
			margin-bottom: 24px;
		}

		.path-section::before {
			content: "";
			position: absolute;
			top: 0;
			left: 20px;
			width: 2px;
			height: 100%;
			background: linear-gradient(180deg, #a855f7, #d946ef, #ec4899);
			opacity: 0.3;
			border-radius: 2px;
		}

		.card-bubble {
			flex-direction: column !important;
		}
		.card-right .card-bubble {
			flex-direction: column !important;
		}
		.card-image {
			width: 100%;
			min-width: 100%;
			height: 150px;
		}
		.card-info {
			padding: 16px 18px 18px;
		}
		.card-name {
			font-size: 1.1rem;
		}
		.modal-image-wrapper {
			height: 170px;
		}
		.modal-body {
			padding: 8px 22px 24px;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 90px 16px 20px;
		}
		.card-image {
			height: 120px;
		}
		.card-name {
			font-size: 1rem;
		}
	}
</style>

<script>
	// === Scroll-driven SVG path trace ===
	const curvePath = document.getElementById(
		"curvePath",
	) as SVGPathElement | null;
	const pathSection = document.querySelector(
		".path-section",
	) as HTMLElement | null;
	let curveLen = 0;
	if (curvePath) {
		curveLen = curvePath.getTotalLength();
		curvePath.style.strokeDasharray = `${curveLen}`;
		curvePath.style.strokeDashoffset = `${curveLen}`;
	}

	window.addEventListener("scroll", () => {
		if (!curvePath || !pathSection) return;
		const rect = pathSection.getBoundingClientRect();
		const sectionTop = rect.top + window.scrollY;
		const sectionHeight = pathSection.offsetHeight;
		const vh = window.innerHeight;

		const scrollStart = sectionTop - vh * 0.5;
		const scrollEnd = sectionTop + sectionHeight - vh * 0.3;
		const progress = Math.max(
			0,
			Math.min(
				1,
				(window.scrollY - scrollStart) / (scrollEnd - scrollStart),
			),
		);

		curvePath.style.strokeDashoffset = (
			curveLen *
			(1 - progress)
		).toString();
	});

	// === Intersection Observer for card reveals ===
	const cards = document.querySelectorAll(".event-card");
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((e) => {
				if (e.isIntersecting) e.target.classList.add("revealed");
			});
		},
		{ threshold: 0.15 },
	);
	cards.forEach((c) => observer.observe(c));

	// === Modal ===
	// Teleport modal to document.body so it's outside any scrollable wrapper
	const modal = document.getElementById("eventModal");
	if (modal) document.body.appendChild(modal);
	const modalImageWrapper = document.getElementById("modalImageWrapper");
	const modalDay = document.getElementById("modalDay");
	const modalTitle = document.getElementById("modalTitle");
	const modalTagline = document.getElementById("modalTagline");
	const modalObjectiveTitle = document.getElementById("modalObjectiveTitle");
	const modalObjective = document.getElementById("modalObjective");
	const modalClose = document.getElementById("modalClose");

	document.querySelectorAll(".event-card").forEach((card) => {
		card.addEventListener("click", () => {
			const el = card as HTMLElement;
			const cardImg = card.querySelector(".card-img") as HTMLImageElement;
			if (cardImg && modalImageWrapper) {
				const img = document.createElement("img");
				img.src = cardImg.src || cardImg.currentSrc;
				img.alt = el.dataset.title || "";
				modalImageWrapper.innerHTML = "";
				modalImageWrapper.appendChild(img);
			}
			if (modalDay) modalDay.textContent = el.dataset.day || "";
			if (modalTitle) modalTitle.textContent = el.dataset.title || "";
			if (modalTagline)
				modalTagline.textContent = el.dataset.tagline || "";
			if (modalObjectiveTitle)
				modalObjectiveTitle.textContent =
					el.dataset.objectiveTitle || "";
			if (modalObjective)
				modalObjective.textContent = el.dataset.objective || "";

			modal?.classList.add("active");
			lockScroll();
		});
	});

	// === Scroll lock using event blockers ===
	let scrollLocked = false;
	function preventScroll(e: Event) {
		// Allow scrolling inside the modal card itself
		const modalCard = document.getElementById("modalCard");
		if (modalCard && modalCard.contains(e.target as Node)) return;
		e.preventDefault();
	}
	function lockScroll() {
		if (scrollLocked) return;
		scrollLocked = true;
		document.addEventListener("wheel", preventScroll, { passive: false });
		document.addEventListener("touchmove", preventScroll, {
			passive: false,
		});
		document.body.style.overflow = "hidden";
		document.documentElement.style.overflow = "hidden";
	}
	function unlockScroll() {
		scrollLocked = false;
		document.removeEventListener("wheel", preventScroll);
		document.removeEventListener("touchmove", preventScroll);
		document.body.style.overflow = "";
		document.documentElement.style.overflow = "";
	}

	function closeModal() {
		modal?.classList.remove("active");
		unlockScroll();
	}

	modalClose?.addEventListener("click", (e) => {
		e.stopPropagation();
		closeModal();
	});
	modal?.addEventListener("click", (e) => {
		if (e.target === modal) closeModal();
	});
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") closeModal();
	});

	// === Move video to fixed container ===
	const videoContainer = document.querySelector(".video-background");
	const fixedContainer = document.getElementById("fixed-video-container");
	if (videoContainer && fixedContainer)
		fixedContainer.appendChild(videoContainer);

	// === Footer reveal ===
	window.addEventListener("load", () => {
		const footer = document.querySelector("footer");
		if (!footer) return;
		footer.classList.add("footer-animate");
		footer.classList.remove("footer-visible");
		window.addEventListener("scroll", () => {
			const pct =
				(window.scrollY + window.innerHeight) /
				document.documentElement.scrollHeight;
			if (pct > 0.8) footer.classList.add("footer-visible");
			else footer.classList.remove("footer-visible");
		});
	});
</script>
