---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import benuniLogo from "../images/benuni.png";

// All sponsors in a single flat array - 3x2 grid
const sponsors = [
  {
    name: "Bennett University",
    logo: benuniLogo,
    description: "Bennett University is a leading institution fostering innovation and technology education.",
    website: "https://www.bennett.edu.in",
  },
  {
    name: "Tech Giant",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Tech+Giant",
    description: "Tech Giant provides cutting-edge solutions for modern businesses.",
    website: "https://example.com",
  },
  {
    name: "Future Systems",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Future+Systems",
    description: "Future Systems specializes in next-generation software development and AI solutions.",
    website: "https://example.com",
  },
  {
    name: "Alpha Code",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Alpha+Code",
    description: "Alpha Code is a premier coding bootcamp and tech community.",
    website: "https://example.com",
  },
  {
    name: "Data Drive",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Data+Drive",
    description: "Data Drive connects businesses with powerful data analytics platforms.",
    website: "https://example.com",
  },
  {
    name: "Orbital",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Orbital",
    description: "Orbital is a student-led tech community organizing hackathons.",
    website: "https://example.com",
  },
];
---

<Layout title="Sponsors | Triverse">
  <div class="sponsors-page">
    <!-- Kinetic Background Glow -->
    <div class="kinetic-glow"></div>

    <!-- Header Section -->
    <section class="sponsors-hero">
      <h1 class="sponsors-title">Our Sponsors</h1>
    </section>

    <!-- Sponsors Grid (3x2) -->
    <section class="sponsors-section">
      <div class="sponsors-grid">
        {sponsors.map((sponsor, index) => (
          <div class="sponsor-card glass-card">
            <!-- Logo Area -->
            <div class="logo-container">
              {typeof sponsor.logo === "string" ? (
                <img src={sponsor.logo} alt={sponsor.name} loading="lazy" />
              ) : (
                <Image src={sponsor.logo} alt={sponsor.name} />
              )}
            </div>

            <!-- Sponsor Name -->
            <h3 class="sponsor-name">{sponsor.name}</h3>

            <!-- Hover Overlay with Details -->
            <div class="hover-overlay">
              <div class="overlay-content">
                <h4 class="overlay-title">{sponsor.name}</h4>
                <p class="overlay-description">{sponsor.description}</p>
                <a href={sponsor.website} target="_blank" rel="noopener noreferrer" class="visit-btn">
                  <span>Visit Website</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  /* === Page Layout === */
  .sponsors-page {
    position: relative;
    min-height: 100vh;
    background: radial-gradient(circle at 50% 40%, #2c0051 0%, #0f0d16 70%);
    overflow-x: hidden;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  /* === Kinetic Background Glow === */
  .kinetic-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 500px;
    background: radial-gradient(ellipse 80% 100% at 50% 0%,
      rgba(138, 43, 226, 0.35) 0%,
      rgba(186, 85, 211, 0.2) 30%,
      rgba(221, 160, 221, 0.1) 50%,
      transparent 100%);
    filter: blur(30px);
    z-index: 0;
    pointer-events: none;
  }

  /* === Hero Section === */
  .sponsors-hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 40px 24px 64px;
  }

  .sponsors-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  /* === Sponsors Section === */
  .sponsors-section {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* === Sponsors Grid (3x2) === */
  .sponsors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* === Glass Card === */
  .glass-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .glass-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  /* === Sponsor Card === */
  .sponsor-card {
    position: relative;
    aspect-ratio: 4/3;
    border-radius: 16px;
    padding: 24px 20px;
    cursor: pointer;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 12px;
  }

  .sponsor-card:hover {
    z-index: 10;
  }

  /* === Logo Container === */
  .logo-container {
    width: 100%;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    transition: all 0.4s ease;
  }

  .logo-container img {
    max-width: 85%;
    max-height: 75px;
    object-fit: contain;
    transition: all 0.4s ease;
    filter: brightness(0.9);
  }

  .sponsor-card:hover .logo-container {
    opacity: 0;
    transform: scale(0.8);
  }

  /* === Sponsor Name === */
  .sponsor-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    opacity: 0.6;
    transition: all 0.4s ease;
  }

  .sponsor-card:hover .sponsor-name {
    opacity: 0;
    transform: translateY(-10px);
  }

  /* === Hover Overlay === */
  .hover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    transform: scale(0.95);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .sponsor-card:hover .hover-overlay {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  .overlay-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    transform: translateY(10px);
    opacity: 0;
    transition: all 0.3s ease 0.1s;
  }

  .sponsor-card:hover .overlay-content {
    transform: translateY(0);
    opacity: 1;
  }

  .overlay-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    text-shadow: 0 2px 10px rgba(0,0,0,0.2);
  }

  .overlay-description {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .visit-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    color: #fff;
    text-decoration: none;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s ease;
    margin-top: 5px;
  }

  .visit-btn:hover {
    background: rgba(255, 255, 255, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .visit-btn svg {
    transition: transform 0.3s ease;
  }

  .visit-btn:hover svg {
    transform: translate(2px, -2px);
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .sponsors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .sponsors-page {
      padding-top: 80px;
    }

    .sponsors-hero {
      padding: 30px 20px 50px;
    }

    .kinetic-glow {
      height: 350px;
    }

    .sponsors-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .sponsor-card {
      padding: 20px 16px;
    }

    .logo-container {
      height: 90px;
    }

    .logo-container img {
      max-height: 65px;
    }

    .overlay-title {
      font-size: 1rem;
    }

    .overlay-description {
      font-size: 0.75rem;
    }

    .visit-btn {
      padding: 8px 14px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .sponsors-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .sponsor-card {
      padding: 16px 12px;
    }

    .logo-container {
      height: 75px;
    }

    .logo-container img {
      max-height: 55px;
    }

    .sponsor-name {
      font-size: 0.85rem;
    }

    .hover-overlay {
      padding: 14px;
    }

    .overlay-description {
      font-size: 0.7rem;
      line-height: 1.4;
    }
  }

  /* === Animation Entrance === */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .sponsor-card {
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  .sponsor-card:nth-child(1) { animation-delay: 0.05s; }
  .sponsor-card:nth-child(2) { animation-delay: 0.1s; }
  .sponsor-card:nth-child(3) { animation-delay: 0.15s; }
  .sponsor-card:nth-child(4) { animation-delay: 0.2s; }
  .sponsor-card:nth-child(5) { animation-delay: 0.25s; }
  .sponsor-card:nth-child(6) { animation-delay: 0.3s; }
</style>
