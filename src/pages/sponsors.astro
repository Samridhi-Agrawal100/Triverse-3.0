---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import benuniLogo from "../images/benuni.png";

// All sponsors in a single flat array - no categories
const sponsors = [
  {
    name: "Bennett University",
    logo: benuniLogo,
    description: "Bennett University is a leading institution fostering innovation and technology education.",
    website: "https://www.bennett.edu.in",
  },
  {
    name: "Tech Giant",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Tech+Giant",
    description: "Tech Giant provides cutting-edge solutions for modern businesses.",
    website: "https://example.com",
  },
  {
    name: "Future Systems",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Future+Systems",
    description: "Future Systems specializes in next-generation software development and AI solutions.",
    website: "https://example.com",
  },
  {
    name: "Alpha Code",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Alpha+Code",
    description: "Alpha Code is a premier coding bootcamp and tech community.",
    website: "https://example.com",
  },
  {
    name: "Beta Devs",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Beta+Devs",
    description: "Beta Devs connects talented developers with exciting projects.",
    website: "https://example.com",
  },
  {
    name: "Club Orbital",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Orbital",
    description: "Club Orbital is a student-led tech community organizing hackathons.",
    website: "https://example.com",
  },
  {
    name: "Nebula Labs",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Nebula",
    description: "Nebula Labs focuses on cloud computing and distributed systems.",
    website: "https://example.com",
  },
  {
    name: "Quantum Tech",
    logo: "https://placehold.co/300x150/1a1a2e/FFF?text=Quantum",
    description: "Quantum Tech is pioneering quantum computing solutions.",
    website: "https://example.com",
  },
];
---

<Layout title="Sponsors | Triverse">
  <div class="sponsors-page">
    <!-- Gradient Header Background -->
    <div class="header-gradient"></div>

    <!-- Hero Section -->
    <section class="hero">
      <h1 class="page-title">Our Sponsors</h1>
      <p class="subtitle">Powering Triverse 3.0 with their incredible support</p>
    </section>

    <!-- Sponsors Grid -->
    <section class="sponsors-section">
      <div class="sponsors-grid">
        {sponsors.map((sponsor, index) => (
          <div class="sponsor-card">
            <!-- Logo Area -->
            <div class="logo-container">
              {typeof sponsor.logo === "string" ? (
                <img src={sponsor.logo} alt={sponsor.name} loading="lazy" />
              ) : (
                <Image src={sponsor.logo} alt={sponsor.name} />
              )}
            </div>
            
            <!-- Sponsor Name -->
            <h3 class="sponsor-name">{sponsor.name}</h3>
            
            <!-- Hover Overlay with Details -->
            <div class="hover-overlay">
              <div class="overlay-content">
                <h4 class="overlay-title">{sponsor.name}</h4>
                <p class="overlay-description">{sponsor.description}</p>
                <a href={sponsor.website} target="_blank" rel="noopener noreferrer" class="visit-btn">
                  <span>Visit Website</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  /* === Page Layout === */
  .sponsors-page {
    position: relative;
    min-height: 100vh;
    background: radial-gradient(ellipse at bottom, #1a0033 0%, #000000 100%);
    overflow-x: hidden;
  }

  /* === Stars Background === */
  .sponsors-page::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(1px 1px at 15% 15%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(1px 1px at 35% 25%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(1px 1px at 55% 45%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(1px 1px at 75% 65%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(1px 1px at 85% 15%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(2px 2px at 10% 80%, rgba(255, 255, 255, 0.7) 50%, transparent 100%),
      radial-gradient(1px 1px at 60% 85%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
    background-size: 550px 550px;
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }

  /* === Gradient Header === */
  .header-gradient {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 500px;
    background: radial-gradient(ellipse 80% 100% at 50% 0%,
      rgba(138, 43, 226, 0.45) 0%,
      rgba(186, 85, 211, 0.3) 30%,
      rgba(221, 160, 221, 0.2) 50%,
      rgba(255, 20, 147, 0.1) 70%,
      transparent 100%);
    filter: blur(25px);
    z-index: 0;
    pointer-events: none;
  }

  /* === Hero Section === */
  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 100px 20px 80px;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 1rem 0;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    font-weight: 400;
  }

  /* === Sponsors Section === */
  .sponsors-section {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px 100px;
  }

  /* === Sponsors Grid === */
  .sponsors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* === Sponsor Card === */
  .sponsor-card {
    position: relative;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 24px 20px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .sponsor-card:hover {
    transform: scale(1.08);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
    z-index: 10;
  }

  /* === Logo Container === */
  .logo-container {
    width: 100%;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    background: #f8f9fa;
    border-radius: 12px;
    transition: all 0.4s ease;
  }

  .logo-container img {
    max-width: 85%;
    max-height: 75px;
    object-fit: contain;
    transition: all 0.4s ease;
  }

  .sponsor-card:hover .logo-container {
    opacity: 0;
    transform: scale(0.8);
  }

  /* === Sponsor Name === */
  .sponsor-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a2e;
    margin: 0;
    transition: all 0.4s ease;
  }

  .sponsor-card:hover .sponsor-name {
    opacity: 0;
    transform: translateY(-10px);
  }

  /* === Hover Overlay === */
  .hover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    transform: scale(0.95);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .sponsor-card:hover .hover-overlay {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  .overlay-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    transform: translateY(10px);
    opacity: 0;
    transition: all 0.3s ease 0.1s;
  }

  .sponsor-card:hover .overlay-content {
    transform: translateY(0);
    opacity: 1;
  }

  .overlay-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    text-shadow: 0 2px 10px rgba(0,0,0,0.2);
  }

  .overlay-description {
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .visit-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.8rem;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s ease;
    margin-top: 5px;
  }

  .visit-btn:hover {
    background: rgba(255, 255, 255, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .visit-btn svg {
    transition: transform 0.3s ease;
  }

  .visit-btn:hover svg {
    transform: translate(2px, -2px);
  }

  /* === Responsive === */
  @media (max-width: 1200px) {
    .sponsors-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 900px) {
    .sponsors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .header-gradient {
      height: 350px;
    }

    .hero {
      padding: 80px 20px 60px;
    }

    .sponsors-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .sponsor-card {
      padding: 20px 16px;
    }

    .logo-container {
      height: 90px;
    }

    .logo-container img {
      max-height: 65px;
    }

    .overlay-title {
      font-size: 1rem;
    }

    .overlay-description {
      font-size: 0.75rem;
    }

    .visit-btn {
      padding: 8px 14px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .sponsors-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .sponsor-card {
      padding: 16px 12px;
    }

    .logo-container {
      height: 75px;
    }

    .logo-container img {
      max-height: 55px;
    }

    .sponsor-name {
      font-size: 0.85rem;
    }

    .hover-overlay {
      padding: 14px;
    }

    .overlay-description {
      font-size: 0.7rem;
      line-height: 1.4;
    }
  }

  /* === Animation Entrance === */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .sponsor-card {
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  .sponsor-card:nth-child(1) { animation-delay: 0.05s; }
  .sponsor-card:nth-child(2) { animation-delay: 0.1s; }
  .sponsor-card:nth-child(3) { animation-delay: 0.15s; }
  .sponsor-card:nth-child(4) { animation-delay: 0.2s; }
  .sponsor-card:nth-child(5) { animation-delay: 0.25s; }
  .sponsor-card:nth-child(6) { animation-delay: 0.3s; }
  .sponsor-card:nth-child(7) { animation-delay: 0.35s; }
  .sponsor-card:nth-child(8) { animation-delay: 0.4s; }
</style>
