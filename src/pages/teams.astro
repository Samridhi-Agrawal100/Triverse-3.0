---
import Layout from "../layouts/Layout.astro";
import TeamSection from "../components/TeamSection.astro";

const heroStars = [
    { top: "10%", left: "15%", delay: "0s" },
    { top: "20%", left: "80%", delay: "1s" },
    { top: "60%", left: "20%", delay: "2s" },
    { top: "40%", left: "60%", delay: "1.5s" },
    { top: "70%", left: "85%", delay: "0.5s" },
    { top: "30%", left: "45%", delay: "2.5s" },
    { top: "80%", left: "10%", delay: "1.2s" },
    { top: "25%", left: "92%", delay: "0.8s" },
    { top: "55%", left: "5%", delay: "1.8s" },
    { top: "15%", left: "70%", delay: "2.3s" },
];

const sectionStars = [
    { top: "20%", left: "20%", delay: "0.7s" },
    { top: "35%", left: "70%", delay: "2.1s" },
    { top: "65%", left: "15%", delay: "1.1s" },
    { top: "45%", left: "90%", delay: "0.4s" },
    { top: "75%", left: "60%", delay: "1.9s" },
    { top: "10%", left: "45%", delay: "2.6s" },
    { top: "55%", left: "8%", delay: "1.4s" },
    { top: "28%", left: "82%", delay: "0.9s" },
    { top: "72%", left: "35%", delay: "2.3s" },
    { top: "88%", left: "78%", delay: "0.5s" },
];

const sections = [
    {
        title: "OFFICE BEARER",
        teamName: "office bearer",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, #0f0a14 0%, #1a1027 50%, #0f0a14 100%)",
        waveFill: "rgb(15, 5, 20)",
    },
    {
        title: "TECH TEAM",
        teamName: "Tech team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, rgb(15, 5, 20) 0%, rgb(20, 8, 30) 50%, rgb(15, 5, 20) 100%)",
        waveFill: "#0f0a14",
    },
    {
        title: "CONTENT TEAM",
        teamName: "Content team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, #0f0a14 0%, #1a1027 50%, #0f0a14 100%)",
        waveFill: "rgb(15, 5, 20)",
    },
    {
        title: "DESIGN TEAM",
        teamName: "Design Team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, rgb(15, 5, 20) 0%, rgb(20, 8, 30) 50%, rgb(15, 5, 20) 100%)",
        waveFill: "#0f0a14",
    },
    {
        title: "PR AND OUTREACH TEAM",
        teamName: "Pr and Outreach Team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, #0f0a14 0%, #1a1027 50%, #0f0a14 100%)",
        waveFill: "rgb(15, 5, 20)",
    },
    {
        title: "MANAGEMENT TEAM",
        teamName: "Management Team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, rgb(15, 5, 20) 0%, rgb(20, 8, 30) 50%, rgb(15, 5, 20) 100%)",
        waveFill: "#0f0a14",
    },
    {
        title: "MULTIMEDIA TEAM",
        teamName: "Multimedia Team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, #0f0a14 0%, #1a1027 50%, #0f0a14 100%)",
        waveFill: "rgb(15, 5, 20)",
    },
    {
        title: "SOCIAL MEDIA TEAM",
        teamName: "Social Media Team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, rgb(15, 5, 20) 0%, rgb(20, 8, 30) 50%, rgb(15, 5, 20) 100%)",
        waveFill: "#0a0a0f",
    },
    {
        title: "RESEARCH TEAM",
        teamName: "research team",
        accent: "#64c8ff",
        accentGlow: "rgba(100, 200, 255, 0.5)",
        background:
            "linear-gradient(180deg, #0a0a0f 0%, #0d0d14 50%, #0a0a0f 100%)",
        waveFill: "rgb(15, 5, 20)",
    },
];
---

<Layout title="Teams - Triverse">
    <main class="teams-page">
        <section class="hero">
            <div class="stars-container">
                {heroStars.map((star) => (
                    <div
                        class="star"
                        style={`top: ${star.top}; left: ${star.left}; animation-delay: ${star.delay};`}
                    ></div>
                ))}
            </div>
            <div class="hero-content">
                <h1 class="hero-title hero-bounce">OUR TEAMS</h1>
                <p class="hero-subtitle">
                    Meet the passionate individuals who make Triverse possible.
                    Our dedicated teams work tirelessly to create an
                    unforgettable experience.
                </p>
            </div>
        </section>

        {sections.map((section, index) => (
            <>
                <section
                    class="team-block"
                    style={`--section-bg: ${section.background}; --accent: ${section.accent}; --accent-glow: ${section.accentGlow};`}
                >
                    <div class="stars-container">
                        {sectionStars.map((star) => (
                            <div
                                class="star"
                                style={`top: ${star.top}; left: ${star.left}; animation-delay: ${star.delay};`}
                            ></div>
                        ))}
                    </div>
                    <div class="team-orb"></div>
                    <div class="team-header">
                        <h2 class="team-title">{section.title}</h2>
                        <div class="team-divider"></div>
                    </div>
                    <div class="team-content">
                        <TeamSection teamName={section.teamName} />
                    </div>
                </section>

                {section.waveFill && (
                    <svg
                        class="wave-divider"
                        viewBox="0 0 1200 240"
                        preserveAspectRatio="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <defs>
                            <linearGradient id={`waveGrad${index + 1}`} x1="0%" y1="100%" x2="0%" y2="0%">
                                <stop offset="0%" stop-color="#7B2CBF" stop-opacity="0.9" />
                                <stop offset="30%" stop-color="#6A1B9A" stop-opacity="0.5" />
                                <stop offset="70%" stop-color="#4A148C" stop-opacity="0.2" />
                                <stop offset="100%" stop-color="#311B92" stop-opacity="0" />
                            </linearGradient>
                            <mask id={`${`waveGrad${index + 1}`}-mask`}>
                                <path d="M0,180 Q300,220 600,180 T1200,180 L1200,0 L0,0 Z" fill="white" />
                            </mask>
                        </defs>
                        <rect x="0" y="0" width="1200" height="240" fill={`url(#waveGrad${index + 1})`} mask={`url(#${`waveGrad${index + 1}`}-mask)`} />
                        <path d="M0,180 Q300,220 600,180 T1200,180 L1200,240 L0,240 Z" fill={section.waveFill} />
                    </svg>
                )}
            </>
        ))}
    </main>

    <style>
        html {
            scroll-behavior: smooth;
        }

        .teams-page {
            color: white;
            overflow-x: hidden;
            max-width: 100vw;
            width: 100%;
        }

        .hero {
            min-height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(
                135deg,
                rgb(15, 5, 20) 0%,
                rgb(20, 8, 30) 50%,
                rgb(15, 5, 20) 100%
            );
            position: relative;
            overflow: hidden;
        }

        .hero-content {
            text-align: center;
            z-index: 10;
            max-width: 900px;
            padding: 20px;
        }

        .hero-title {
            font-size: 4.5rem;
            font-weight: 700;
            margin-bottom: 20px;
            text-shadow: 0 0 30px rgba(100, 200, 255, 0.6),
                0 0 60px rgba(100, 200, 255, 0.3);
            letter-spacing: 4px;
            background: linear-gradient(135deg, #fff 0%, #64c8ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-subtitle {
            font-size: 1.2rem;
            line-height: 1.6;
            color: #c8d8e8;
            text-shadow: 0 0 10px rgba(100, 200, 255, 0.3);
            font-weight: 300;
            max-width: 700px;
            margin: 0 auto;
        }

        .hero-bounce {
            animation: heroFloat 6s ease-in-out infinite;
        }

        .team-block {
            min-height: auto;
            background: var(--section-bg);
            padding: 25px 20px 140px;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .team-orb {
            position: absolute;
            top: 30%;
            left: -10%;
            width: 450px;
            height: 450px;
            background: radial-gradient(
                circle,
                rgba(100, 200, 255, 0.12) 0%,
                transparent 70%
            );
            border-radius: 50%;
            filter: blur(70px);
            pointer-events: none;
        }

        .team-header {
            text-align: center;
            margin-bottom: 25px;
            position: relative;
            z-index: 2;
        }

        .team-title {
            font-size: 2.8rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--accent);
            text-shadow: 0 0 20px var(--accent-glow);
            letter-spacing: 3px;
        }

        .team-divider {
            width: 100px;
            height: 4px;
            background: linear-gradient(
                90deg,
                transparent,
                var(--accent),
                transparent
            );
            margin: 0 auto;
            border-radius: 2px;
            box-shadow: 0 0 15px var(--accent-glow);
        }

        .team-content {
            position: relative;
            z-index: 2;
        }

        .wave-divider {
            position: relative;
            width: 100%;
            height: 240px;
            display: block;
            margin-top: -240px;
            z-index: 50;
        }

        .stars-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .star {
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 0 6px rgba(255, 255, 255, 0.9),
                0 0 12px rgba(255, 255, 255, 0.5);
            animation: twinkle 3s infinite ease-in-out;
        }

        @keyframes heroFloat {
            0% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-10px);
            }
            100% {
                transform: translateY(0);
            }
        }

        @keyframes twinkle {
            0%,
            100% {
                opacity: 0.2;
                transform: scale(1);
            }
            50% {
                opacity: 1;
                transform: scale(1.4);
            }
        }

        @media (max-width: 768px) {
            .hero-title {
                font-size: 3rem;
            }

            .team-title {
                font-size: 2rem;
            }
        }
    </style>
</Layout>
