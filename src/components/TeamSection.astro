---
import { Image } from 'astro:assets';
import teamData from '../data/team-details.json';

interface Props {
  teamName: string;
}

const { teamName } = Astro.props;

const normalizeTeamName = (value: string | undefined | null) =>
  value?.trim().toLowerCase() ?? '';

const normalizedTeamName = normalizeTeamName(teamName);
const team = teamData.teams.find(t => normalizeTeamName(t.name) === normalizedTeamName);

if (!team) {
  console.error(`Team "${teamName}" not found`);
}

const hasCoLead = Boolean(team?.colead);
const isOfficeBearerTeam = team?.name.toLowerCase() === 'office bearer';

// Load all team images eagerly
const teamImages = import.meta.glob<{ default: ImageMetadata }>('/src/images/team/**/*.{png,jpg,jpeg,webp,PNG,JPG,JPEG,WEBP}', { eager: true });

function resolveImage(path: string | undefined | null) {
  if (!path) return null;
  // Normalize path: replace backslashes with forward slashes
  const normalizedPath = path.replace(/\\/g, '/');
  // Ensure it starts with /team
  const cleanPath = normalizedPath.startsWith('/') ? normalizedPath : '/' + normalizedPath;
  // Construct full path
  const fullPath = `/src/images${cleanPath}`;
  
  const imageModule = teamImages[fullPath];
  return imageModule ? imageModule.default : null;
}

type PersonCard = {
  name: string;
  role: string;
  image?: string | null;
  heading: 'h3' | 'h4';
};

const people: PersonCard[] = team
  ? [
      { ...team.lead, heading: 'h3' as const },
      ...(hasCoLead ? [{ ...team.colead, heading: 'h3' as const }] : []),
      ...team.members.map(member => ({ ...member, heading: 'h4' as const })),
    ]
  : [];
---
{team && (
  <section class="team-section">

    <!-- ALL MEMBERS IN GRID -->
    <div class="members-grid" class:list={isOfficeBearerTeam ? 'office-bearer-layout' : ''}>
      {people.map(person => {
        const personImage = resolveImage(person.image);
        const HeadingTag = person.heading;
        const infoContent = (
          <>
            <HeadingTag>{person.name}</HeadingTag>
            <p>{person.role}</p>
          </>
        );

        return (
          <div class="member-card reveal">
            <div class="avatar-wrap member-avatar">
              {personImage ? (
                <Image src={personImage} alt={person.name} class="team-img" />
              ) : (
                <div class="placeholder-img"></div>
              )}
              <div class="info">{infoContent}</div>
              <div class="info info-hover">{infoContent}</div>
            </div>
          </div>
        );
      })}
    </div>

  </section>
)}

<script>
  const revealCards = () => {
    const cards = document.querySelectorAll('.member-card.reveal');
    if (!('IntersectionObserver' in window)) {
      cards.forEach(card => card.classList.add('is-visible'));
      return;
    }
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          } else {
            entry.target.classList.remove('is-visible');
          }
        });
      },
      { root: null, rootMargin: '0px 0px -10% 0px', threshold: 0.2 }
    );
    cards.forEach(card => observer.observe(card));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', revealCards);
  } else {
    revealCards();
  }
</script>

<style>
/* ---------- SECTION ---------- */
.team-section {
  max-width: 1100px;
  margin: 0rem auto 0;
  padding: 0 1rem;
}

/* ---------- AVATAR WITH GALAXY BACKGROUND ---------- */
.avatar-wrap {
  position: relative;
  width: 240px;
  height: 320px;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(15, 5, 20, 0.3) 0%, rgba(30, 15, 45, 0.5) 30%, rgba(60, 20, 100, 0.85) 60%, rgba(100, 40, 160, 0.9) 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  border-radius: 8px;
  box-shadow: 0 4px 16px rgba(100, 50, 200, 0.1);
  z-index: 100;
}

.avatar-wrap .info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px 15px 15px;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.5) 50%, rgba(0, 0, 0, 0.85) 100%);
  z-index: 2;
  text-align: center;
}

.avatar-wrap .info h3,
.avatar-wrap .info h4 {
  margin: 0 0 5px 0;
  font-size: 1.1rem;
  font-weight: 600;
  color: #fff;
}

.avatar-wrap .info p {
  margin: 0;
  font-size: 0.9rem;
  color: #ddd;
}

/* ---------- SIMPLE IMAGE ---------- */
.team-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
  background: transparent;
  transform: none;
  transition: transform 0.3s ease;
  border-radius: 6px;
}

.avatar-wrap:hover .team-img {
  transform: scale(1.02);
}

.avatar-wrap:hover .info:not(.info-hover) {
  opacity: 0;
}

.avatar-wrap .info-hover {
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.avatar-wrap:hover .info-hover {
  opacity: 1;
  transform: translateY(0);
}

/* ---------- MEMBERS GRID ---------- */
.members-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.2rem;
  margin-top: 0.5rem;
  justify-items: center;
}

/* Office Bearer Special Layout: Strictly 2 on top, 3 on bottom */
.members-grid.office-bearer-layout {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 1.2rem;
  margin-top: 0.5rem;
  justify-items: center;
}

.members-grid.office-bearer-layout > .member-card:nth-child(1) {
  grid-column: 2 / 4;
  grid-row: 1;
}

.members-grid.office-bearer-layout > .member-card:nth-child(2) {
  grid-column: 4 / 6;
  grid-row: 1;
}

.members-grid.office-bearer-layout > .member-card:nth-child(3) {
  grid-column: 1 / 3;
  grid-row: 2;
}

.members-grid.office-bearer-layout > .member-card:nth-child(4) {
  grid-column: 3 / 5;
  grid-row: 2;
}

.members-grid.office-bearer-layout > .member-card:nth-child(5) {
  grid-column: 5 / 7;
  grid-row: 2;
}

/* ---------- MEMBER CARD ---------- */
.member-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: transform 0.3s ease;
}

.member-card:hover {
  transform: translateY(-10px);
}

/* ---------- SCROLL REVEAL ---------- */
.member-card.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
  will-change: opacity, transform;
}

.member-card.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  .member-card.reveal,
  .member-card.reveal.is-visible {
    transition: none;
    transform: none;
  }
}

.member-avatar {
  margin-bottom: 0.45rem;
}

/* ---------- RESPONSIVE ---------- */
@media (max-width: 941px) {
  .members-grid {
    grid-template-columns: 1fr;
  }

  .avatar-wrap {
    width: 150px;
    height: 150px;
  }

  .avatar-wrap .info {
    padding: 10px 8px 8px;
  }

  .avatar-wrap .info h3,
  .avatar-wrap .info h4 {
    font-size: 0.95rem;
  }

  .avatar-wrap .info p {
    font-size: 0.75rem;
  }

  .avatar-wrap .info-hover {
    background: rgba(0, 0, 0, 0.45);
  }

  .members-grid.office-bearer-layout {
    grid-template-columns: 1fr;
  }

  .members-grid.office-bearer-layout > .member-card,
  .members-grid.office-bearer-layout > .member-card:nth-child(1),
  .members-grid.office-bearer-layout > .member-card:nth-child(2),
  .members-grid.office-bearer-layout > .member-card:nth-child(3),
  .members-grid.office-bearer-layout > .member-card:nth-child(4),
  .members-grid.office-bearer-layout > .member-card:nth-child(5) {
    grid-column: 1 / -1;
    grid-row: auto;
  }
}
</style>
